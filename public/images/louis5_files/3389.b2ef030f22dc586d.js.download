G:`${i.A.SERVICES.VIPER.DOMAIN}/pending`,FLEX:`${i.A.SERVICES.VIPER.DOMAIN}/flex`,HISTORY:`${i.A.SERVICES.VIPER.DOMAIN}/history`,FINANCES:`${i.A.SERVICES.VIPER.DOMAIN}/finances`,PROFESSIONAL_TOOLS:`${i.A.SERVICES.VIPER.DOMAIN}/professional-tools`,ADVERTISING:`${i.A.SERVICES.VIPER.DOMAIN}/advertising`}},67922:(e,t,r)=>{r.d(t,{A:()=>F});var i=r(41554),n=r(27861),a=r(36439),d=r(81877),s=r(44978),o=r(9316),c=r(95719),l=r(78807),u=r(29688),m=r(34869),p=r(53544),A=r(58270);let _={query:`fragment CustomerAsksActivity on AsksConnection {
  edges {
    node {
      id
      amount
      inventoryType
      productVariant {
        id
        product {
          id
          styleId
        }
      }
      marketAdjustedPrice(market: $market) {
        adjustedAmount
        currencyCode
      }
    }
  }
  pageInfo {
    totalCount
  }
}

fragment CustomerBids on BidsConnection {
  edges {
    node {
      id
      amount
      automatedBiddingEnabled
      marketAdjustedPrice(market: $market) {
        adjustedAmount
        currencyCode
      }
    }
  }
  pageInfo {
    totalCount
  }
}

query getCustomerActivityForProduct($productId: String!, $currencyCode: CurrencyCode, $market: String, $isVariant: Boolean! = false) {
  variantAsk: viewer @include(if: $isVariant) {
    uuid
    asks(
      currencyCode: $currencyCode
      filters: {variantId: {in: [$productId]}, expired: {is: false}, askType: {in: [STANDARD]}}
      first: 1
      order: ASC
      state: CURRENT
      sort: PRICE
    ) {
      ...CustomerAsksActivity
    }
  }
  parentAsk: viewer @skip(if: $isVariant) {
    uuid
    asks(
      currencyCode: $currencyCode
      filters: {productId: {in: [$productId]}, expired: {is: false}, askType: {in: [STANDARD]}}
      first: 1
      order: ASC
      state: CURRENT
      sort: PRICE
    ) {
      ...CustomerAsksActivity
    }
  }
  variantBid: viewer @include(if: $isVariant) {
    uuid
    bids(
      currencyCode: $currencyCode
      filters: {variantId: {in: [$productId]}, expired: {is: false}}
      first: 1
      order: DESC
      state: CURRENT
      sort: AMOUNT
    ) {
      ...CustomerBids
    }
  }
  parentBid: viewer @skip(if: $isVariant) {
    uuid
    bids(
      currencyCode: $currencyCode
      filters: {productId: {in: [$productId]}, expired: {is: false}}
      first: 1
      order: DESC
      state: CURRENT
      sort: AMOUNT
    ) {
      ...CustomerBids
    }
  }
}`,queryId:"69811efbc6518d6320d613acb8aa890dbfc15877eae0a1f4dc893d96473ab10c",name:"getCustomerActivityForProduct",kind:"query"},y=e=>({variantId:e.productVariant?.id??"",productId:e.productVariant?.product?.id??"",styleId:e.productVariant?.product?.styleId??""}),g=e=>{if(!e)return;let t=[];if(e.variantAsk?.asks?.edges?.length){let r=e.variantAsk.asks.edges[0]?.node,i=y(r);t.push({id:r?.id??"",amount:r?.amount??"",type:"ask",variantId:i.variantId,productId:i.productId,styleId:i.styleId,inventoryType:r?.inventoryType??void 0,marketAdjustedPrice:{...r?.marketAdjustedPrice}})}if(e.parentAsk?.asks?.edges?.length){let r=e.parentAsk.asks.edges[0]?.node,i=y(r);t.push({id:r?.id??"",amount:r?.amount??"",type:"ask",variantId:i.variantId,productId:i.productId,styleId:i.styleId,inventoryType:r?.inventoryType??void 0,marketAdjustedPrice:{...r?.marketAdjustedPrice}})}return e.variantBid?.bids?.edges?.length&&t.push({id:e.variantBid.bids.edges[0]?.node?.id??"",amount:e.variantBid.bids.edges[0]?.node?.amount??"",type:"bid",automatedBiddingEnabled:e.variantBid.bids.edges[0]?.node?.automatedBiddingEnabled??void 0,marketAdjustedPrice:{...e.variantBid.bids.edges[0]?.node?.marketAdjustedPrice}}),e.parentBid?.bids?.edges?.length&&t.push({id:e.parentBid.bids.edges[0]?.node?.id??"",amount:e.parentBid.bids.edges[0]?.node?.amount??"",type:"bid",automatedBiddingEnabled:e.parentBid.bids.edges[0]?.node?.automatedBiddingEnabled??void 0,marketAdjustedPrice:{...e.parentBid.bids.edges[0]?.node?.marketAdjustedPrice}}),t};var b=r(52037),v=r(43525),I=r(51808),k=r(79176),f=r(5083),C=r(70116),h=r(48113),S=r(24277),E=r(49170),R=r(16631),T=r(12356),B=r(59993),x=r(91533),D=r(86911),$=r(39053),N=r(30455),P=r(19094),w=r(86314),V=r(34839),O=r(1442);let z=e=>{let t,r,d,s,o,c,u,m,p,A,_,y=(0,n.c)(36),{item:g,isIntrazone:z}=e,Y=void 0!==z&&z,{type:F,id:U,amount:j,marketAdjustedPrice:L,variantId:M,productId:q,styleId:G,automatedBiddingEnabled:J}=g,{t:Z}=(0,b.Bd)(),W="base"===(0,I.A)(),H=(0,x.A)(),K=(0,T.n)(),{url: