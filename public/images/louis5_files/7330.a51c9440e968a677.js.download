query FetchMarketHistory($productId: String!, $currencyCode: CurrencyCode, $market: String, $isVariant: Boolean! = false, $viewerContext: MarketViewerContext) {
  variant(id: $productId) @include(if: $isVariant) {
    id
    market(currencyCode: $currencyCode) {
      ...MarketHistory
    }
  }
  product(id: $productId) @skip(if: $isVariant) {
    id
    market(currencyCode: $currencyCode) {
      ...MarketHistory
    }
  }
}`,queryId:"0ad63aa6b0ba4b8874e7e8957f44191c57a7482d5578cfb9662651c49bc85164",name:"FetchMarketHistory",kind:"query"};var w=i(51808);let Y={fontSize:"md",paddingY:"2",paddingX:"0",_notLast:{borderWidth:"0 0 1px 0",borderColor:"outline-secondary",borderStyle:"solid"}},k={...Y,fontWeight:"normal",color:"text-primary",gridColumn:"1"},A={...Y,color:"text-primary",textAlign:"right",gridColumn:"2"},$=e=>{let t,i,d,s,c,m,h,u=(0,a.c)(18),{stat:p}=e,{t:g}=(0,n.Bd)();u[0]!==p||u[1]!==g?(t=p?.title?g(p.title??""):"\xa0",u[0]=p,u[1]=g,u[2]=t):t=u[2],u[3]!==t?(i=(0,r.Y)(o.EYj,{as:"span",children:t}),u[3]=t,u[4]=i):i=u[4],u[5]!==p||u[6]!==g?(d=p?.subtitle?`(${g(p.subtitle??"")})`:"",u[5]=p,u[6]=g,u[7]=d):d=u[7],u[8]!==d?(s=(0,r.Y)(o.EYj,{as:"span",marginLeft:"1",children:d}),u[8]=d,u[9]=s):s=u[9],u[10]!==i||u[11]!==s?(c=(0,r.FD)(o.azJ,{as:"dt",sx:k,children:[i,s]}),u[10]=i,u[11]=s,u[12]=c):c=u[12];let y=p?.value||"\xa0";return u[13]!==y?(m=(0,r.Y)(o.azJ,{as:"dd",sx:A,children:y}),u[13]=y,u[14]=m):m=u[14],u[15]!==c||u[16]!==m?(h=(0,r.FD)(l.Fragment,{children:[c,m]}),u[15]=c,u[16]=m,u[17]=h):h=u[17],h},z=e=>{let t,i,l=(0,a.c)(4),{stats:n}=e;return l[0]!==n?(t=n.map(S),l[0]=n,l[1]=t):t=l[1],l[2]!==t?(i=(0,r.Y)(o.azJ,{as:"dl",display:"grid","data-component":"List",children:t}),l[2]=t,l[3]=i):i=l[3],i};function S(e,t){return(0,r.Y)($,{stat:e},t)}var q=i(48717),C=i(38295),H=i(94706),M=i(57775),F=i(83307),D=i(39018),E=i(67204);let L={bg:"background-accent-1",px:6,py:2,alignContent:"center",dl:{display:"grid"},borderRadius:"md"},j={textAlign:"left",margin:0,fontFamily:"suisseIntlMedium",fontSize:["lg","xl"],color:"text-primary"},I={color:"text-primary",fontFamily:"suisseIntlMedium",fontSize:["xs","sm"],textAlign:"left",margin:0},W=e=>{let t,i,l,d,s,c,m=(0,a.c)(16),{stat:h}=e,{t:u}=(0,n.Bd)();m[0]!==h?.title||m[1]!==u?(t=h?.title?u(h?.title??""):"\xa0",m[0]=h?.title,m[1]=u,m[2]=t):t=m[2],m[3]!==t?(i=(0,r.Y)(o.EYj,{as:"span",variant:"medium",fontSize:"sm",children:t}),m[3]=t,m[4]=i):i=m[4]