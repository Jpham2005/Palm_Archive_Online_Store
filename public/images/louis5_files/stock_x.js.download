;(function() {
    
    // TTD Pixel ---
    function ensureScriptLoaded(src) {
        console.log("Ensuring script is loaded:", src);
        return new Promise((resolve, reject) => {
            const existingScript = document.querySelector(`script[src="${src}"]`);
            if (existingScript) {
                resolve();
                return;
            }
    
            const script = document.createElement('script');
            script.src = src;
            script.async = true;
            script.onload = () => {
                resolve();
            };
            script.onerror = () => {
                console.error(`Error loading script: ${src}`);
                reject(new Error(`Script load error for ${src}`));
            };
            document.head.appendChild(script);
        });
    }

    function ttd_fire_pixel() {
        try {
            ensureScriptLoaded('https://js.adsrvr.org/up_loader.1.1.0.js')
                .then(() => {
                    ttd_dom_ready(function() {
                        if (typeof TTDUniversalPixelApi === 'function') {
                            var universalPixelApi = new TTDUniversalPixelApi();
                            universalPixelApi.init("t7hohkt", ["iwiikw8"], "https://insight.adsrvr.org/track/up");
                        }
                    });
                });
        } catch (error) {
            console.log("TTD Pixel not fired from LWD Pixel: ", error);
        }
    }
    //---

    function amazon_fire_pixel(event_name, data = null) {
    (function (w, d) {
        function onAmznLoad() {
        let tries = 0;
        (function ready() {
            if (typeof w.amzn === "function" && !w.amzn.q) {
            try {
                w.amzn("setRegion", "NA");
                w.amzn("addTag", "53249e61-b58b-4e24-95cd-a2bc45769b0c"); 

                if (data && data.order_id != null) {
                w.amzn("trackEvent", event_name, {
                    transaction_id: data.order_id,
                    event_value: data.value
                });
                } else {
                w.amzn("trackEvent", event_name);
                }
            } catch (e) {
                console.error("amazon tracking error:", e);
            }
            return;
            }
            if (++tries > 30) {
            console.error("amzn never became callable");
            return;
            }
            setTimeout(ready, 100);
        })();
        }

        function onAmznError(e) {
        console.error("failed to load amazon script", e || "");
        }

        if (!w.amzn || typeof w.amzn !== "function") {
        var a, s, t;

        a = w.amzn = function () {
            (w.amzn.q = w.amzn.q || []).push([arguments, Date.now()]);
        };
        var prevQ = (w.amzn && w.amzn.q) || [];
        a.q = a.q || [];
        if (prevQ.length) a.q = prevQ.concat(a.q);
        a.version = "0.0";

        s = d.createElement("script");
        s.src = "https://c.amazon-adsystem.com/aat/amzn.js";
        s.id = "amzn-pixel";
        s.async = true;

        var cs = d.currentScript, nz = cs && (cs.nonce || cs.getAttribute("nonce"));
        if (nz) s.setAttribute("nonce", nz);

        t = d.getElementsByTagName("script")[0];
        (t && t.parentNode ? t.parentNode : (d.head || d.documentElement)).insertBefore(s, t || null);

        s.onload = onAmznLoad;
        s.onerror = onAmznError;
        } else {
        onAmznLoad();
        }
    })(window, document);
    }

    const lw_pixel_id = 145;
    const SESSION_EXPIRY_TIME = 1800000; // 30 min

    const patterns = {
        email: /^[\w-.]+@[a-zA-Z0-9-]+\.[a-zA-Z0-9-.]{2,}$/,
        phone: /^1?\d{10}$/
    };

    async function hashValue(str) {
        const encoder = new TextEncoder();
        const data = encoder.encode(str.trim().toLowerCase());
        const hashBuffer = await crypto.subtle.digest('SHA-256', data);
        return [...new Uint8Array(hashBuffer)]
            .map(b => b.toString(16).padStart(2, '0'))
            .join('');
    }

    function setCookie(name, value, days) {
        var expires = "";
        if (days) {
            var date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            expires = "; expires=" + date.toUTCString();
        }
        document.cookie = name + "=" + (value || "") + expires + "; path=/";
    }

    function getCookie(name) {
        var nameEQ = name + "=";
        var ca = document.cookie.split(';');
        for (var i = 0; i < ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == ' ') c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
        }
        return null;
    }

    function generateID(prefix) {
        return `${prefix}-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
    }

    function getSessionID() {
        const currentSessionID = sessionStorage.getItem('sessionID');
        const sessionExpiry = sessionStorage.getItem('sessionExpiry');
        const now = Date.now();
        
        if (!currentSessionID || !sessionExpiry || now > parseInt(sessionExpiry, 10)) {
            return createNewSession();
        }
        
        sessionStorage.setItem('sessionExpiry', now + SESSION_EXPIRY_TIME); // Extend session
        return currentSessionID;
    }

    function createNewSession() {
        const sessionID = generateID('session');
        sessionStorage.setItem('sessionID', sessionID);
        sessionStorage.setItem('sessionExpiry', Date.now() + SESSION_EXPIRY_TIME);
        return sessionID;
    }

    function getClientID() {
        const cookieName = 'lw_clientID';
        let clientID = getCookie(cookieName);
        
        if (!clientID) {
            clientID = generateID('client');
            setCookie(cookieName, clientID, 90); // Set cookie for 90 days
        }
        return clientID;
    }

    const lw_sessionID = getSessionID();
    const lw_clientID = getClientID();

    function getUrlParameter(url, name) {
        const regex = new RegExp(`[?&]${name.replace(/[[\]]/g, '\\$&')}=([^&#]*)`);
        const results = regex.exec(url);
        return results ? decodeURIComponent(results[1].replace(/\+/g, ' ')) : '';
    }

    function getReferrerData(url) {
        return {
            source: getUrlParameter(url, 'utm_source'),
            medium: getUrlParameter(url, 'utm_medium'),
            campaign: getUrlParameter(url, 'utm_campaign'),
        };
    }

    function getReferrerHostname() {
        return document.referrer ? new URL(document.referrer).hostname : null;
    }

    async function fetchIPData() {
        try {
            const response = await fetch("https://api.ipdata.co/?api-key=0d5e0d3777e6cc2db2201382a813b1ff31ee341af30f5e8473e8c4f2", {
                headers: { "Accept": "application/response" }
            });
            const ipData = await response.json();
            sessionStorage.setItem('ipData', JSON.stringify(ipData));
            return ipData;
        } catch (error) {
            console.log("IP Data fetch error: ", error);
            return null;
        }
    }

    function imgCreation(src, alt=false) {
        const img = document.createElement('img');
        img.src = src;
        img.style.display = 'none';
        img.width = 1;
        img.height = 1;
        if (alt) { img.alt = "" }
        document.body.appendChild(img);
    }

    async function getIPData() {
        const ipData = sessionStorage.getItem('ipData');
        return ipData ? JSON.parse(ipData) : await fetchIPData();
    }

    async function trackEvent(eventType, data, orderNumber, ctx = {} ) {
        eventType = eventType.toLowerCase();
        ctx = ctx || {};
        const {
            currentUrl      = window.location.href,
            referrerData    = getReferrerData(window.location.href),
            referrerHostname= getReferrerHostname(),
            timestamp       = Date.now(),
            cacheBuster     = Math.floor(Math.random() * 1e20)
        } = ctx;

        if (eventType === 'phone') {
            data = data.replace(/\D/g, '');

            if (!patterns.phone.test(data)) {
                return;
            }

            data = await hashValue(data);
        } else if (eventType === 'email') {
            if (!patterns.email.test(data)) {
                return;
            }
            data = await hashValue(data);
        }

        const ipData = await getIPData();
        const payload = {
            lw_pixel_id,
            lw_clientID,
            lw_sessionID,
            lw_event: eventType,
            lw_event_value: data,
            lw_event_order_value: orderNumber,
            lw_medium: referrerData.medium,
            lw_source: referrerData.source,
            lw_campaign: referrerData.campaign,
            lw_pagepath: currentUrl,
            lw_referrer: referrerHostname,
            lw_datetime: timestamp,
            lw_cache_buster: cacheBuster
        };
        if (ipData) {
            Object.assign(payload, {
            lw_ip_address: ipData.ip || '',
            lw_internet_type: ipData.asn?.type || '',
            lw_internet_provider: ipData.company?.name || '',
            lw_zip_code: ipData.postal || '',
            lw_city: ipData.city || '',
            lw_state: ipData.region || '',
            lw_country: ipData.country_code || '',
            lw_tor: ipData.threat?.is_tor ? 1 : 0,
            lw_relay: ipData.threat?.is_icloud_relay ? 1 : 0,
            lw_datacenter: ipData.threat?.is_datacenter ? 1 : 0,
            lw_bogon: ipData.threat?.is_bogon ? 1 : 0,
            lw_vpn: ipData.threat?.is_vpn ? 1 : 0,
            lw_anonymous: ipData.threat?.is_anonymous ? 1 : 0,
            lw_known_attacker: ipData.threat?.is_known_attacker ? 1 : 0,
            lw_known_abuser: ipData.threat?.is_known_abuser ? 1 : 0,
            lw_proxy: ipData.threat?.is_proxy ? 1 : 0,
            lw_threat: ipData.threat?.is_threat ? 1 : 0,
            lw_trust_score: ipData.threat?.scores?.trust_score || 0,
            lw_threat_score: ipData.threat?.scores?.threat_score || 0,
            lw_proxy_score: ipData.threat?.scores?.proxy_score || 0,
            lw_vpn_score: ipData.threat?.scores?.vpn_score || 0
            });
        }
        const url = `https://dgbixniqt3.execute-api.us-east-2.amazonaws.com/trackingPixeProcessing/?${new URLSearchParams(payload).toString()}`;
        imgCreation(url, true);
    }

    window.lw_trackEvent = trackEvent;
    
    // SPA
    let lastPath = null;
    let popstateInit = true;
    
    function onRouteChange() {
        const rawPath = new URL(window.location.href).pathname;
        if (rawPath === lastPath) return;
        lastPath = rawPath;
        trackEvent('PageView', 1, '');
        console.log("pageview");
        amazon_fire_pixel('PageView');
        ttd_fire_pixel();
    }
    
    ['pushState','replaceState'].forEach(fn => {
      const orig = history[fn];
      history[fn] = function() {
        orig.apply(this, arguments);
        onRouteChange();
      };
    });
    
    window.addEventListener('popstate', () => {
      if (popstateInit) {
        popstateInit = false;
        return;
      }
      onRouteChange();
    });
    
    onRouteChange();
})();