  enabled
  amount
  roundedAmount
}

query getRecentlyViewedProducts($id: String!, $currencyCode: CurrencyCode, $countryCode: String!, $marketName: String, $limit: Int!, $includeProcessingFeeForPricing: Boolean = false) {
  product(id: $id) {
    id
    recentlyViewed: related(
      input: {country: $countryCode, type: RECENTLY_VIEWED, limit: $limit}
    ) {
      edges {
        node {
          id
          listingType
          title
          brand
          urlKey
          gender
          browseVerticals
          favorite
          categories {
            default {
              alias
              level
            }
          }
          variants {
            id
          }
          media {
            smallImageUrl
          }
          market(currencyCode: $currencyCode) {
            salesInformation {
              lastSale
            }
            state(country: $countryCode, market: $marketName) {
              lowestAsk {
                amount
              }
              askServiceLevels {
                standard {
                  processingFee @include(if: $includeProcessingFeeForPricing) {
                    ...ProcessingFeeFields
                  }
                  count
                  lowest {
                    amount
                    inventoryType
                  }
                }
                expressExpedited {
                  processingFee @include(if: $includeProcessingFeeForPricing) {
                    ...ProcessingFeeFields
                  }
                  count
                  lowest {
                    amount
                    inventoryType
                  }
                }
                expressStandard {
                  processingFee @include(if: $includeProcessingFeeForPricing) {
                    ...ProcessingFeeFields
                  }
                  count
                  lowest {
                    amount
                    inventoryType
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}`,queryId:"0006e37bfd87047019ca920c1ac9304dc7ed3b3e7d7d88983d12ac569077e4c6",name:"getRecentlyViewedProducts",kind:"query"},v=e=>e?.product?.recentlyViewed?.edges?.reduce((e,t)=>(t?.node?.id&&e.push({...t.node,id:t.node.id}),e),[])??[];var F=r(46060);let E=(0,i.memo)(({onVisibilityChange:e})=>{let{ref:t,inView:r}=(0,c.Wx)({triggerOnce:!0}),{data:E=[],isPending:C}=(e=>{let t,r,n,i,o=(0,b.c)(13);o[0]!==e?(t=void 0===e?{}:e,o[0]=e,o[1]=t):t=o[1];let{enabled:l}=t,{countryCode:c,currencyCode:a,marketName:d}=(0,f.A)(),{data:s}=(0,A.A)(),u=s?.id??"",m=(0,S.t3)(P._I);o[2]!==m?(r=(0,k.H)(m),o[2]=m,o[3]=r):r=o[3],o[4]!==c||o[5]!==a||o[6]!==u||o[7]!==d||o[8]!==r?(n={id:u,limit:15,currencyCode:a,countryCode:c,marketName:d,includeProcessingFeeForPricing:r},o[4]=c,o[5]=a,o[6]=u,o[7]=d,o[8]=r,o[9]=n):n=o[9];let y=(void 0===l||l)&&!!u;return o[10]!==n||o[11]!==y?(i={variables:n,enabled:y,select:v},o[10]=n,o[11]=y,o[12]=i):i=o[12],(e=>{let t,r,n,i=(0,b.c)(9),o=e?.variables;if(i[0]!==o)t=o?["getRecentlyViewedProducts",o]:["getRecentlyViewedProducts"],i[0]=o,i[1]=t;else t=i[1];return i[2]!==e?.context||i[3]!==e?.requestOptions?(r=t=>{let r,{signal:n,queryKey:i}=t,[,o]=i;return r={variables:o,options:e?.requestOptions,context:e?.context,signal:n},(0,x.Z)({operation:{...B,variables:r?.variables},options:r?.options,context:r?.context,signal:r?.signal})},i[2]=e?.context,i[3]=e?.requestOptions,i[4]=r):r=i[4],i[5]!==e||i[6]!==t||i[7]!==r?(n={queryKey:t,queryFn:r,...e},i[5]=e,i[6]=t,i[7]=r,i[8]=n):n=i[8],(0,w.I)(n)})(i)})({enabled:r}),{queryId:R,queryIndex:Y}=(0,p.A)(e=>e),{currency:I}=(0,u.H)(),L=(0,i.useCallback)((e,t)=>{(0,m.A)(y.A.PRODUCT_TILE,{swooshName:d.R.PDPRecentlyViewedSwoosh,screenName:g.A.PRODUCT,productUUID:e.id,productName:e.title,productBrand:e?.brand,hasImage:!(0,h.g)(e?.media?.smallImageUrl),position:t+1,currency:I,queryID:R,index:Y,objectID:e.uuid,lowestAsk:e?.market?.state?.lowestAsk?.amount,inventoryType:(0,_.MA)({market:e?.market})?"flex":"standard",lowestCustodialAsk: