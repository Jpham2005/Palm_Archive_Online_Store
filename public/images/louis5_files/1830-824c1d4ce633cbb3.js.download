  enabled
  amount
  roundedAmount
}

query GetMarketData($id: String!, $currencyCode: CurrencyCode, $marketName: String, $viewerContext: MarketViewerContext, $includeProcessingFeeForPricing: Boolean!) {
  product(id: $id) {
    id
    urlKey
    listingType
    title
    uuid
    contentGroup
    sizeDescriptor
    productCategory
    lockBuying
    lockSelling
    media {
      imageUrl
    }
    minimumBid(currencyCode: $currencyCode)
    market(currencyCode: $currencyCode) {
      state(market: $marketName) {
        lowestAsk {
          amount
          chainId
        }
        highestBid {
          amount
        }
        askServiceLevels {
          expressNextDay {
            processingFee @include(if: $includeProcessingFeeForPricing) {
              ...ProcessingFeeFields
            }
            count
            lowest {
              amount
              chainId
              inventoryType
            }
            delivery {
              expectedDeliveryDate
              latestDeliveryDate
            }
          }
          expressExpedited {
            processingFee @include(if: $includeProcessingFeeForPricing) {
              ...ProcessingFeeFields
            }
            count
            lowest {
              amount
              chainId
              inventoryType
            }
            delivery {
              expectedDeliveryDate
              latestDeliveryDate
            }
          }
          expressStandard {
            processingFee @include(if: $includeProcessingFeeForPricing) {
              ...ProcessingFeeFields
            }
            count
            lowest {
              amount
              chainId
              inventoryType
            }
            delivery {
              expectedDeliveryDate
              latestDeliveryDate
            }
          }
          standard {
            processingFee @include(if: $includeProcessingFeeForPricing) {
              ...ProcessingFeeFields
            }
            count
            lowest {
              amount
              chainId
            }
          }
        }
        numberOfAsks
        numberOfBids
      }
      salesInformation {
        lastSale
        salesLast72Hours
      }
      statistics(market: $marketName, viewerContext: $viewerContext) {
        lastSale {
          amount
          changePercentage
          changeValue
          sameFees
        }
        last90Days {
          averagePrice
          salesCount
        }
      }
    }
    variants {
      id
      market(currencyCode: $currencyCode) {
        state(market: $marketName) {
          lowestAsk {
            amount
            chainId
          }
          highestBid {
            amount
          }
          askServiceLevels {
            expressNextDay {
              processingFee @include(if: $includeProcessingFeeForPricing) {
                ...ProcessingFeeFields
              }
              count
              lowest {
                amount
                chainId
                inventoryType
              }
              delivery {
                expectedDeliveryDate
                latestDeliveryDate
              }
            }
            expressExpedited {
              processingFee @include(if: $includeProcessingFeeForPricing) {
                ...ProcessingFeeFields
              }
              count
              lowest {
                amount
                chainId
                inventoryType
              }
              delivery {
                expectedDeliveryDate
                latestDeliveryDate
              }
            }
            expressStandard {
              processingFee @include(if: $includeProcessingFeeForPricing) {
                ...ProcessingFeeFields
              }
              count
              lowest {
                amount
                chainId
                inventoryType
              }
              delivery {
                expectedDeliveryDate
                latestDeliveryDate
              }
            }
            standard {
              processingFee @include(if: $includeProcessingFeeForPricing) {
                ...ProcessingFeeFields
              }
              count
              lowest {
                amount
                chainId
              }
            }
          }
          numberOfAsks
          numberOfBids
        }
        salesInformation {
          lastSale
          salesLast72Hours
        }
        statistics(market: $marketName, viewerContext: $viewerContext) {
          lastSale {
            amount
            changePercentage
            changeValue
            sameFees
          }
          last90Days {
            averagePrice
            salesCount
          }
        }
      }
    }
  }
