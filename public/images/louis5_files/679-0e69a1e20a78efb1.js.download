  id
  name
  type
  ... on BrowseFilterTree {
    isCollapsed
    multiSelectEnabled
    options {
      id
      name
      count
      selected
      children
      level
      value
    }
  }
  ... on BrowseFilterList {
    isCollapsed
    multiSelectEnabled
    listFilterStyle: style
    options {
      id
      name
      count
      selected
      value
    }
  }
  ... on BrowseFilterBoolean {
    id
    name
    type
    selected
    booleanFilterStyle: style
  }
  ... on BrowseFilterRange {
    id
    isCollapsed
    name
    type
    minimum {
      value
    }
    maximum {
      value
    }
    minSelected {
      value
    }
    maxSelected {
      value
    }
  }
  ... on BrowseFilterColor {
    id
    isCollapsed
    name
    type
    options {
      name
      value
      count
      selected
      swatchColor
      borderColor
    }
  }
}

fragment ProcessingFeeFields on AskServiceLevelProcessingFee {
  enabled
  amount
  roundedAmount
}

fragment DiscoveryProductFragment on Product {
  id
  title
  name
  urlKey
  brand
  gender
  description
  model
  condition
  productCategory
  browseVerticals
  listingType
  primaryCategory
  uuid
  categories {
    default {
      alias
      level
    }
  }
  favorite
  variants {
    id
  }
  media {
    thumbUrl
    smallImageUrl
  }
  traits(filterTypes: [RELEASE_DATE]) {
    name
    value
  }
  market(currencyCode: $currency) {
    state(country: $country, market: $market) {
      highestBid {
        amount
        updatedAt
      }
      lowestAsk {
        amount
        updatedAt
      }
      askServiceLevels {
        standard {
          processingFee @include(if: $includeProcessingFeeForPricing) {
            ...ProcessingFeeFields
          }
          count
          lowest {
            amount
            inventoryType
          }
        }
        expressNextDay {
          processingFee @include(if: $includeProcessingFeeForPricing) {
            ...ProcessingFeeFields
          }
          count
          lowest {
            amount
            inventoryType
          }
        }
        expressExpedited {
          processingFee @include(if: $includeProcessingFeeForPricing) {
            ...ProcessingFeeFields
          }
          count
          lowest {
            amount
            inventoryType
          }
        }
        expressStandard {
          processingFee @include(if: $includeProcessingFeeForPricing) {
            ...ProcessingFeeFields
          }
          count
          lowest {
            amount
            inventoryType
          }
        }
      }
    }
    statistics(market: $market) {
      annual {
        averagePrice
        volatility
        salesCount
        pricePremium
      }
      last72Hours {
        salesCount
      }
      last90Days {
        averagePrice
        salesCount
      }
      lastSale {
        amount
      }
    }
  }
}

fragment DiscoveryMysteryBoxFragment on MysteryBox {
  id
  name
  description
  availableUnits
  state
  amountUsd
  amountLocal
  currencyLocal
  priceDetails {
    currency
    amount
    meta {
      floor
      ceiling
      average
    }
  }
  product {
    id
    title
    name
    urlKey
    brand
    gender
    description
    model
    condition
    productCategory
    browseVerticals
    listingType
    primaryCategory
    uuid
    categories {
      default {
        alias
        level
      }
    }
    favorite
    variants {
      id
    }
    media {
      thumbUrl
      smallImageUrl
    }
    traits(filterTypes: [RELEASE_DATE]) {
      name
      value
    }
  }
  tiers {
    tierLevel
    id
  }
}

query getDiscoveryData($country: String!, $currency: CurrencyCode, $filters: [BrowseFilterInput], $flow: BrowseFlow, $market: String, $query: String, $sort: BrowseSortInput, $page: BrowsePageInput, $unifiedDiscoveryEnabled: Boolean, $enableMysteryBox: Boolean = false, $includeProcessingFeeForPricing: Boolean!) {
  browse(
    filters: $filters
    flow: $flow
    sort: $sort
    page: $page
    market: $market
    query: $query
    experiments: {ads: {enabled: true}, dynamicFilter: {enabled: true}, dynamicFilterDefinitions: {enabled: true}, multiselect: {enabled: true}, openSearch: {enabled: $unifiedDiscoveryEnabled}, unifiedDiscovery: {enabled: $unifiedDiscoveryEnabled}}
  ) {
    filtersConfig {
      quick {
        ...FiltersFragment
      }
      advanced {
        ...FiltersFragment
      }
    }
    results {
      edges {
        isAd
        adIdentifier
        adServiceLevel
        adInventoryId
        objectId
        node {
          __typename
          ... on Variant {
            id
            favorite
            market(currencyCode: $currency) {
              state(country: $country, market: $market) {
                highestBid {
                  amount
                  updatedAt
                }
                lowestAsk {
                  amount
                  updatedAt
                }
                askServiceLevels {
                  standard {
                    processingFee @include(if: $includeProcessingFeeForPricing) {
                      ...ProcessingFeeFields
                    }
                    count
                    lowest {
                      amount
                      inventoryType
                    }
                  }
                  expressNextDay {
                    processingFee @include(if: $includeProcessingFeeForPricing) {
                      ...ProcessingFeeFields
                    }
                    count
                    lowest {
                      amount
                      inventoryType
                    }
                  }
                  expressExpedited {
                    processingFee @include(if: $includeProcessingFeeForPricing) {
                      ...ProcessingFeeFields
                    }
                    count
                    lowest {
                      amount
                      inventoryType
                    }
                  }
                  expressStandard {
                    processingFee @include(if: $includeProcessingFeeForPricing) {
                      ...ProcessingFeeFields
                    }
                    count
                    lowest {
                      amount
                      inventoryType
                    }
                  }
                }
              }
              statistics(market: $market) {
                annual {
                  averagePrice
                  volatility
                  salesCount
                  pricePremium
                }
                last72Hours {
                  salesCount
                }
                last90Days {
                  averagePrice
                  salesCount
                }
                lastSale {
                  amount
                }
              }
            }
            product {
              id
              name
              urlKey
              title
              brand
              gender
              description
              model
              condition
              productCategory
              browseVerticals
              listingType
              media {
                thumbUrl
                smallImageUrl
              }
              traits(filterTypes: [RELEASE_DATE]) {
                name
                value
              }
            }
            sizeChart {
              baseSize
              baseType
              displayOptions {
                size
                type
              }
            }
          }
          ... on Product {
            ...DiscoveryProductFragment
          }
          ... on SellerListing {
            id
            productVariant {
              sizeChart {
                baseType
                baseSize
              }
              product {
                title
                urlKey
              }
              traits {
                size
              }
            }
            amount
            market {
              state {
                askServiceLevels {
                  standard {
                    processingFee @include(if: $includeProcessingFeeForPricing) {
                      ...ProcessingFeeFields
                    }
                    lowest {
                      amount
                    }
                  }
                }
              }
            }
            media {
              images {
                alt
                url
              }
            }
            conditionDetails: condition {
              alias
              value
            }
            isOwner
          }
          ... on MysteryBox @include(if: $enableMysteryBox) {
            ...DiscoveryMysteryBoxFragment
          }
          ... on BrowseListingGroup {
            numberOfListings
            product {
              id
              title
            }
            topListings {
              amount
              market {
                state {
                  askServiceLevels {
                    standard {
                      processingFee @include(if: $includeProcessingFeeForPricing) {
                        ...ProcessingFeeFields
                      }
                      lowest {
                        amount
                      }
                    }
                  }
                }
              }
              media {
                images {
                  url
                }
              }
              isOwner
            }
            minListing {
              market {
                state {
                  askServiceLevels {
                    standard {
                      processingFee @include(if: $includeProcessingFeeForPricing) {
                        ...ProcessingFeeFields
                      }
                      lowest {
                        amount
                      }
                    }
                  }
                }
              }
            }
            maxListing {
              market {
                state {
                  askServiceLevels {
                    standard {
                      processingFee @include(if: $includeProcessingFeeForPricing) {
                        ...ProcessingFeeFields
                      }
                      lowest {
                        amount
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
      pageInfo {
        limit
        page
        pageCount
        queryId
        queryIndex
        total
      }
    }
    seo {
      title
      blurb
      richBlurb
      meta {
        name
        value
      }
    }
    sort {
      id
      name
      description
      seoUrlKey
      short
    }
  }
}`,queryId:"0dfb92175acd1f87d7f346510faf2efa139de20cb9a98e0a081de7beadeaa986",name:"getDiscoveryData",kind:"query"},a=e=>(0,i.Z)({operation:{...n,variables:e?.variables},options:e?.options,context:e?.context,signal:e?.signal})},36699:(e,t,r)=>{r.d(t,{EP:()=>c,GH:()=>m,RL:()=>l,RS:()=>n,Tw:()=>o,X5:()=>s,Yw:()=>u,bO:()=>a,w3:()=>d});var i=r(21150);let n=(0,i.JU)({key:"giftcard_navItem_new_label_web",description:"Enable new label for gift card navigation item",permanent:!1}),a=(0,i.Ey)({key:"ab_mystery_boxes_v1_web",description:"Mystery Boxes MVP",permanent:!1}),s=(0,i.Ey)({key:"ab_t22y8_web",description:"Flex Ads carousel on browse pages",permanent:!1}),o=(0,i.Jt)({key:"mystery_box_supported_countries_and_currencies_all",description:"Mystery Box Supported Countries and Currencies",permanent:!0,defaultValue:{SUPPORTED_COUNTRY:["US"],SUPPORTED_CURRENCY:["USD"],US:["USD"],USD:["US"]}}),l=(0,i.JU)({key:"enable_seller_kyb_verification_feature_all",description:"Enable seller KYB verification feature",permanent:!0}),c=(0,i.JU)({key:"live_enable_stockx_all",description:"Enable StockX Live",permanent:!1}),d=(0,i.JU)({key:"live_enable_uat_web",description:"Enable Live UAT-ready features",permanent:!1}),u=(0,i.Jt)({key:"ab_omgv8_web",description:"Checkout overbid warning: variant shows modal, control auto-switches to buy",permanent:!1,defaultValue:"false",values:["false","true","neither"]}),m=(0,i.Ey)({key:"ab_fopua_web",description:"mWeb search & browse in-feed Google display ads after every 5th product grid row",permanent:!1})},53553:(e,t,r)=>{r.d(t,{A:()=>a});var i=r(66314),n=r(78807);let a=()=>{let e=(0,n.A)(),{region:t}=(0,i.A)();return e?.marketName??t??"US"}},62199:(e,t,r)=>{r.d(t,{A:()=>a});var i=r(66314),n=r(78807);let a=()=>{let e=(0,n.A)(),{region:t}=(0,i.A)();return e?.marketCountry||t||"US"}},79210:(e,t,r)=>{r.d(t,{A:()=>n});var i=r(34295);let n=()=>(0,i.q9)()},80678:(e,t,r)=>{r.d(t,{A:()=>o});var i=r(27861),n=r(36982),a=r(96614),s=r(62199);let o=()=>{let e,t=(0,i.