  product(id: $id) {
    primaryTitle
    traits {
      format
      name
      value
    }
    market(currencyCode: $currencyCode) {
      statistics {
        annual {
          averagePrice
          salesCount
        }
      }
    }
    listings(page: $page) {
      results {
        edges {
          node {
            ... on SellerListing {
              __typename
              id
              amount
              conditionDescription
              condition {
                alias
                value
              }
              market(currencyCode: $currencyCode) {
                state(market: $market) {
                  askServiceLevels {
                    standard {
                      lowest {
                        amount
                      }
                    }
                  }
                }
              }
              media {
                images {
                  alt
                  url
                }
              }
              productVariant {
                traits {
                  size
                  sizeDescriptor
                }
                product {
                  urlKey
                  id
                  productCategory
                  primaryCategory
                  primaryTitle
                  secondaryTitle
                  title
                  model
                  description
                  contentGroup
                  listingType
                  deleted
                  gender
                  browseVerticals
                  categories {
                    default {
                      alias
                      level
                    }
                  }
                  styleId
                  editionType
                  sizeAllDescriptor
                  availableSizeConversions {
                    name
                    type
                  }
                  defaultSizeConversion {
                    name
                    type
                  }
                  media {
                    smallImageUrl
                    thumbUrl
                    imageUrl
                  }
                  tags
                  traits {
                    name
                    value
                    visible
                    format
                  }
                  condition
                }
                sizeChart {
                  baseSize
                  baseType
                  displayOptions {
                    size
                    type
                  }
                }
              }
            }
          }
        }
      }
    }
  }
