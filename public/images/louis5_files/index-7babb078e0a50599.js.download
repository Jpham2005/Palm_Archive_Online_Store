fragment MenuEntry on MenuCollectionSectionEntry {
  name
  link {
    url
    urlType
  }
}

query getMenuCollections($shouldFetchSubMenus: Boolean! = false, $version: Int) {
  menuCollection(type: DESKTOP, version: $version) {
    name
    type
    textColor
    link {
      url
      urlType
    }
    sections @include(if: $shouldFetchSubMenus) {
      name
      link {
        url
        urlType
      }
      entries {
        ...MenuEntrySubLevel
      }
    }
  }
