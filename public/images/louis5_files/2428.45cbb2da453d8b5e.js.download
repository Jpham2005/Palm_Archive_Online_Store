      market: $marketName
      set: DISPLAY
      version: 2
    ) {
      badgeID
      title
      subtitle
      context {
        key
        value
        format
      }
      textColor
      backgroundColor
      borderColor
      darkModeIcon {
        url
        alt
      }
      lightModeIcon {
        url
        alt
      }
      icon {
        url
        alt
      }
    }
    counterfactualBadges: badges(
      currencyCode: $currencyCode
      market: $marketName
      set: COUNTERFACTUAL
      version: 2
    ) {
      badgeID
      context {
        key
        value
        format
      }
    }
    variants {
      id
      badges: badges(
        currencyCode: $currencyCode
        market: $marketName
        set: DISPLAY
        version: 2
      ) {
        badgeID
        title
        subtitle
        context {
          key
          value
          format
        }
        textColor
        backgroundColor
        borderColor
        darkModeIcon {
          url
          alt
        }
        lightModeIcon {
          url
          alt
        }
        icon {
          url
          alt
        }
      }
      counterfactualBadges: badges(
        currencyCode: $currencyCode
        market: $marketName
        set: COUNTERFACTUAL
        version: 2
      ) {
        badgeID
        context {
          key
          value
          format
        }
      }
    }
  }
