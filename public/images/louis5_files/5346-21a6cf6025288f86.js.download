  favorite
}

query RecentlyViewedProducts($type: ProductSelectionType!, $limit: Int!, $country: String!, $currencyCode: CurrencyCode!, $marketName: String, $includeProcessingFeeForPricing: Boolean!) {
  allProducts(type: $type, page: {page: 0, limit: $limit}) {
    edges {
      node {
        id
        listingType
        title
        brand
        productCategory
        name
        urlKey
        uuid
        gender
        browseVerticals
        categories {
          default {
            alias
            level
          }
        }
        ...FavoriteProductFragment
        variants {
          id
        }
        media {
          smallImageUrl
        }
        market(currencyCode: $currencyCode) {
          state(country: $country, market: $marketName) {
            lowestAsk {
              amount
            }
            askServiceLevels {
              standard {
                processingFee @include(if: $includeProcessingFeeForPricing) {
                  enabled
                  amount
                  roundedAmount
                }
                count
                lowest {
                  amount
                  inventoryType
                }
              }
              expressExpedited {
                processingFee @include(if: $includeProcessingFeeForPricing) {
                  enabled
                  amount
                  roundedAmount
                }
                count
                lowest {
                  amount
                  inventoryType
                }
              }
              expressStandard {
                processingFee @include(if: $includeProcessingFeeForPricing) {
                  enabled
                  amount
                  roundedAmount
                }
                count
                lowest {
                  amount
                  inventoryType
                }
              }
            }
          }
          salesInformation {
            lastSale
          }
        }
      }
    }
  }
