query GetProductPriceLevels($productId: String!, $market: String, $currencyCode: CurrencyCode, $transactionType: TransactionType, $page: Int, $limit: Int, $isVariant: Boolean!) {
  product(id: $productId) @skip(if: $isVariant) {
    id
    market(currencyCode: $currencyCode) {
      ...MarketPriceLevelsFragment
    }
  }
  variant(id: $productId) @include(if: $isVariant) {
    id
    market(currencyCode: $currencyCode) {
      ...MarketPriceLevelsFragment
    }
  }
}`,queryId:"54257c7f2fe6c85bc75d239dc5290080c4d7bf605dcb80cd68a656907096acb3",name:"GetProductPriceLevels",kind:"query"}},84461:(e,t,r)=>{r.d(t,{M:()=>a});let a=({variants:e,variantId:t,sizeLocale:r})=>{if(!t||!e||!r)return null;let a=e?.find(e=>e?.id===t);if(!a?.sizeChart?.baseSize||!a?.sizeChart?.displayOptions)return null;let i=r&&a.sizeChart.displayOptions.find(e=>e?.type?.toUpperCase()===r.toUpperCase()),n=i&&i.size?i.size:null;return n??a.sizeChart.displayOptions[0]?.size??""}},85441:(e,t,r)=>{r.d(t,{A:()=>u});var a=r(41554),i=r(27861);r(36439);var n=r(92169),l=r(52037),o=r(80678),s=r(79176),d=r(7819),c=r(97215);let m=()=>{let e,t,r,o,d=(0,i.c)(6),{t:c}=(0,l.Bd)();return d[0]===Symbol.for("react.memo_cache_sentinel")?(e={base:"block",md:"inline"},d[0]=e):e=d[0],d[1]===Symbol.for("react.memo_cache_sentinel")?(t={textDecoration:"underline"},d[1]=t):t=d[1],d[2]!==c?(r=c("Learn More"),d[2]=c,d[3]=r):r=d[3],d[4]!==r?(o=(0,a.Y)(s.azJ,{as:"span",display:e,children:(0,a.Y)(n.A,{"aria-describedby":"disclaimer-text",sx:t,fontWeight:"bold",as:"EXTERNAL",to:"https://stockx.com/help/it-IT/articles/What-costs-are-associated-with-my-purchase",children:r})}),d[4]=r,d[5]=o):o=d[5],o},u=()=>{let e,t,r,n,u=(0,i.c)(7),{t:p}=(0,l.Bd)(),h=(0,o.A)(),_=(0,d.A)()===c.g.Home;u[0]!==_||u[1]!==p?(e=p(_?"homepage_italy_cosumer_protection_disclaimer":"pdp_italy_cosumer_protection_disclaimer"),u[0]=_,u[1]=p,u[2]=e):e=u[2];let y=e;return"IT"!==h?null:(u[3]===Symbol.for("react.memo_cache_sentinel")?(t={base:0,md:2},u[3]=t):t=u[3],u[4]===Symbol.for("react.memo_cache_sentinel")?(r=(0,a.Y)(m,{}),u[4]=r):r=u[4],u[5]!==y?(n=(0,a.Y)(s.son,{pt:2,pb:t,direction:"column",alignItems:"flex-start",children:(0,a.FD)(s.EYj,{fontSize:"sm",id:"disclaimer-text",children:[y," ",r]})}),u[5]=y,u[6]=n):n=u[6],n)}},86968:(e,t,r)=>{r.d(t,{F5:()=>a});let a={query:`fragment MarketSalesFragment on Market {
