  __typename
  id
  favorite
  urlKey
  productCategory
  primaryCategory
  brand
  name
  model
  listingType
  lockBuying
  lockSelling
  title
  gender
  browseVerticals
  market(currencyCode: $currencyCode) {
    ...RelatedProductMarketFragment
  }
  media {
    smallImageUrl
  }
  variants {
    id
    hidden
  }
}

fragment RelatedProductMarketFragment on Market {
  state(country: $countryCode, market: $marketName) {
    askServiceLevels {
      standard {
        processingFee @include(if: $includeProcessingFeeForPricing) {
          ...ProcessingFeeFields
        }
        count
        lowest {
          amount
          inventoryType
        }
      }
      expressExpedited {
        processingFee @include(if: $includeProcessingFeeForPricing) {
          ...ProcessingFeeFields
        }
        count
        lowest {
          amount
          inventoryType
        }
      }
      expressStandard {
        processingFee @include(if: $includeProcessingFeeForPricing) {
          ...ProcessingFeeFields
        }
        count
        lowest {
          amount
          inventoryType
        }
      }
      expressNextDay {
        processingFee @include(if: $includeProcessingFeeForPricing) {
          ...ProcessingFeeFields
        }
        count
        lowest {
          amount
          inventoryType
        }
      }
    }
    lowestAsk {
      amount
    }
    highestBid {
      amount
    }
  }
  statistics {
    lastSale {
      amount
    }
  }
}

fragment ProcessingFeeFields on AskServiceLevelProcessingFee {
  enabled
  amount
  roundedAmount
}

fragment RelatedProductVariantFragment on Variant {
  __typename
  id
  favorite
  sizeChart {
    baseSize
    baseType
    displayOptions {
      size
      type
    }
  }
  traits {
    size
    sizeDescriptor
  }
  product {
    ...RelatedProductFragment
  }
  market(currencyCode: $currencyCode) {
    ...RelatedProductMarketFragment
  }
}

query fetchRelatedProducts($productId: String!, $countryCode: String!, $variantId: String, $currencyCode: CurrencyCode, $type: RelatedProductsType, $limit: Int!, $marketName: String, $isVariantRelatedProducts: Boolean!, $placement: Placement, $includeProcessingFeeForPricing: Boolean!) {
  product(id: $productId) @skip(if: $isVariantRelatedProducts) {
    id
    productCategory
    related(
      input: {type: $type, country: $countryCode, market: $marketName, limit: $limit, placement: $placement}
    ) {
      results {
        adIdentifier
        adInventoryId
        adServiceLevel
        node {
          ... on Product {
            ...RelatedProductFragment
          }
          ... on Variant {
            ...RelatedProductVariantFragment
          }
        }
      }
    }
  }
  variant(id: $variantId) @include(if: $isVariantRelatedProducts) {
    related(
      input: {type: $type, market: $marketName, limit: $limit, placement: $placement}
    ) {
      results {
        adIdentifier
        adInventoryId
        adServiceLevel
        node {
          ... on Product {
            ...RelatedProductFragment
          }
          ... on Variant {
            ...RelatedProductVariantFragment
          }
        }
      }
    }
  }
}`,queryId:"0b7532355f967a26e69d33c4a0b9212b23a633eacf1829469b7896dbd2a03f40",name:"fetchRelatedProducts",kind:"query"},Y=e=>({results:(e?.product?.related?.results??e?.variant?.related?.results??[]).flatMap(e=>e?[e]:[]),parentId:e?.product?.id});var S=r(27136),C=r(90320),x=r(70116),w=r(48113),F=r(59681),D=r(22279),I=r(15591),E=r(90854);let P=e=>null!=e.node,$=(0,o.memo)(e=>{let t,r,n=(0,i.c)(4),{results:l}=e;n[0]!==l?(t=l.filter(P).map(L).filter(Boolean),n[0]=l,n[1]=t):t=n[1];let o=t;return n[2]!==o?(r=(0,a.Y)(E.A,{children:o}),n[2]=o,n[3]=r):r=n[3],r});function L(e,t){let{node:r}=e,i=!!e.adIdentifier,n="Variant"===r.__typename,l=n?r.product:r,o=n?r.sizeChart:void 0,s=n?r.market:void 0;return l?(0,a.Y)(I.A,{index:t,product:l,isAd:i,adInventoryId:e.adInventoryId,adIdentifier:e.adIdentifier,adServiceLevel:e.adServiceLevel??null,sizeChart:o,variantMarket:i?s:null,variantId:i?r.id:null,swooshName:"Related Products",footerProps:{footerType:"last_sale",displaySize:!0}},`related-products-carousel-${r.id}-${t}`):null}let z=(0,o.memo)(()=>{let e,t,r,I,E,P,L,z,T,R,B,V,U,j=(0,i.c)(38),O="base"===(0,d.A)(),W=(0,p.A)(),H=(0,l.A)(),N=(0,C.A)(),{t:K}=(0,s.Bd)(),q=(!O||W)&&!H;j[0]!==q?(e={triggerOnce:!0,rootMargin:"100px",initialInView:q},j[0]=q,j[1]=e):e=j[1];let{ref:G,inView:J}=(0,m.Wx)(e),Q=N?S.W.DYNAMIC_LANDING_PAGE:S.W.PRODUCT;j[2]!==J||j[3]!==Q?(t={enabled:J,productsType:S.kd5.RELATED,placement:Q},j[2]=J,j[3]=Q,j[4]=t):t=j[4];let{data:X,error:Z,isFetched:ee}=(e=>{let t,r,a,n,l=(0,i.c)(19),{enabled:o,productsType:s,placement:d,limit:c}=e,m=void 0===c?15:c,{productId:u,countryCode:p,currencyCode:S,marketName:C}=(0,b.A)(),{data:x}=(0,g.A)(),w=(0,f.A)(),F=!!w,D=x?.id,I=(0,h.q9)(),E=(0,h.t3)(_._I),P=void 0!==o&&o&&(!!u||!!w)&&!!D,$=u??"",L=w??"";l[0]!==E?(t=(0,y.H)(E),l[0]=E,l[1]=t):t=l[1],l[2]!==p||l[3]!==S||l[4]!==F||l[5]!==m||l[6]!==C||l[7]!==d||l[8]!==s||l[9]!==$||l[10]!==L||l[11]!==t?(r={productId:$,variantId:L,currencyCode:S,countryCode:p,marketName:C,limit:m,type:s,isVaria