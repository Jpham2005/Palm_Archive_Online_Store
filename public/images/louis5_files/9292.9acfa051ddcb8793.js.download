query GetProductMarketSales($productId: String!, $currencyCode: CurrencyCode, $market: String, $first: Int, $isVariant: Boolean!, $viewerContext: MarketViewerContext) {
  product(id: $productId) @skip(if: $isVariant) {
    id
    market(currencyCode: $currencyCode) {
      ...MarketSalesFragment
    }
  }
